<Window
    x:Class="DiametroLineaDesktop.Views.WeightToDensityDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Density from Measured Weight"
    Width="370" SizeToContent="Height"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
    Background="#12151C"
    FontFamily="Segoe UI"
    ShowInTaskbar="False">

    <Window.Resources>
        <SolidColorBrush x:Key="Accent"      Color="#2D7DD2"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#E2E8F4"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#7A8499"/>
        <SolidColorBrush x:Key="PanelBg"     Color="#1C2030"/>
        <SolidColorBrush x:Key="BorderCol"   Color="#2E3548"/>
        <SolidColorBrush x:Key="Success"     Color="#28C996"/>
        <SolidColorBrush x:Key="InputBg"     Color="#232837"/>

        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,3,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderCol}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Border Background="#1C2030" BorderBrush="#2E3548" BorderThickness="1" Margin="1">
        <StackPanel Margin="20">

            <!-- Heading -->
            <TextBlock Text="Density from Measured Weight"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimary}"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Enter the weighed mass to back-calculate specific density (ρ = m / V)."
                       FontSize="11" Foreground="{StaticResource TextMuted}"
                       TextWrapping="Wrap" Margin="0,0,0,18"/>

            <!-- Scope -->
            <TextBlock Text="WHAT DID YOU WEIGH?"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="{StaticResource TextMuted}"
                       Margin="0,0,0,6"/>
            <RadioButton x:Name="WholeLineRadio" Content="Whole line"
                         IsChecked="True" Checked="Scope_Changed" Margin="0,0,0,0"/>
            <RadioButton x:Name="HeadRadio" Content="Head segments only"
                         Checked="Scope_Changed"/>
            <RadioButton x:Name="CustomRadio" Content="Custom segment selection"
                         Checked="Scope_Changed"/>

            <!-- Segment checklist (shown for Custom scope) -->
            <Border x:Name="SegmentListBorder" Visibility="Collapsed"
                    BorderBrush="#2E3548" BorderThickness="1"
                    Margin="0,8,0,0" CornerRadius="4">
                <ScrollViewer MaxHeight="150" VerticalScrollBarVisibility="Auto"
                              Background="#12151C" Padding="10,6">
                    <StackPanel x:Name="SegmentListPanel"/>
                </ScrollViewer>
            </Border>

            <!-- Divider -->
            <Rectangle Height="1" Fill="#2E3548" Margin="0,18,0,14"/>

            <!-- Volume row -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Volume of selection:"
                           FontSize="12" Foreground="{StaticResource TextMuted}"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="VolumeDisplay" Grid.Column="1"
                           Text="— cm³"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimary}"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- Weight input row -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="88"/>
                    <ColumnDefinition Width="26"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Measured weight:"
                           FontSize="12" Foreground="{StaticResource TextMuted}"
                           VerticalAlignment="Center"/>
                <TextBox x:Name="WeightBox" Grid.Column="1"
                         TextChanged="WeightBox_TextChanged"/>
                <TextBlock Grid.Column="2" Text=" g"
                           FontSize="12" Foreground="{StaticResource TextMuted}"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- Density result -->
            <Grid Margin="0,0,0,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Calculated density:"
                           FontSize="12" Foreground="{StaticResource TextMuted}"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="DensityDisplay"
                               Text="—"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource Success}"/>
                    <TextBlock Text=" g/cm³"
                               FontSize="12" Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Bottom" Margin="3,0,0,2"/>
                </StackPanel>
            </Grid>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="ApplyBtn" Content="Apply"
                        Click="ApplyBtn_Click"
                        IsEnabled="False" IsDefault="True"
                        Width="90" Height="30"
                        FontSize="12" FontWeight="SemiBold"
                        Foreground="White" BorderThickness="0"
                        Cursor="Hand" Margin="0,0,8,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="#2D7DD2" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.62"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="Cancel"
                        Click="CancelBtn_Click"
                        IsCancel="True"
                        Width="90" Height="30"
                        FontSize="12"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="#232837"
                                    BorderBrush="#2E3548" BorderThickness="1"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  TextBlock.Foreground="#7A8499"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.75"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.55"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
