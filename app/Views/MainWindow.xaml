<Window
        x:Class="DiametroLineaDesktop.Views.MainWindow"
        x:Name="MainWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        xmlns:local="clr-namespace:DiametroLineaDesktop.Views"
        mc:Ignorable="d"
        Title="FlyLine Profiler"
        Icon="/Assets/icon.ico"
        Height="900"
        Width="1400"
        MinHeight="780"
        MinWidth="900"
        Background="#12151C"
        FontFamily="Segoe UI">

    <Window.Resources>

        <SolidColorBrush x:Key="WinBg"        Color="#12151C"/>
        <SolidColorBrush x:Key="PanelBg"      Color="#1C2030"/>
        <SolidColorBrush x:Key="CardBg"       Color="#232837"/>
        <SolidColorBrush x:Key="BorderBrush2" Color="#2E3548"/>
        <SolidColorBrush x:Key="Accent"       Color="#2D7DD2"/>
        <SolidColorBrush x:Key="AccentDim"    Color="#1A4F8A"/>
        <SolidColorBrush x:Key="Danger"       Color="#E85454"/>
        <SolidColorBrush x:Key="Success"      Color="#28C996"/>
        <SolidColorBrush x:Key="Warning"      Color="#F5A623"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#E2E8F4"/>
        <SolidColorBrush x:Key="TextMuted"    Color="#7A8499"/>
        <SolidColorBrush x:Key="LogBg"        Color="#0D0F16"/>

        <local:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <local:HexToBrushConverter  x:Key="HexToBrush"/>

        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Height"          Value="34"/>
            <Setter Property="Padding"         Value="14,0"/>
            <Setter Property="Margin"          Value="2,0"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.80"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.60"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.30"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="{StaticResource Danger}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="BtnSecondary" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="#2C3245"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>

        <Style x:Key="BtnGhost" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        </Style>

        <Style x:Key="ToggleBase" TargetType="ToggleButton">
            <Setter Property="Height"          Value="34"/>
            <Setter Property="Padding"         Value="14,0"/>
            <Setter Property="Margin"          Value="2,0"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background"      Value="#2C3245"/>
            <Setter Property="Foreground"      Value="{StaticResource TextMuted}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentDim}"/>
                                <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.80"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.30"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolSep" TargetType="Separator">
            <Setter Property="Width"      Value="1"/>
            <Setter Property="Height"     Value="22"/>
            <Setter Property="Margin"     Value="8,0"/>
            <Setter Property="Background" Value="#2E3548"/>
        </Style>

        <Style x:Key="MetricCard" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="10"/>
            <Setter Property="Padding"         Value="14,8"/>
            <Setter Property="Margin"          Value="0,0,8,0"/>
            <Setter Property="MinWidth"        Value="110"/>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
        </Style>

        <!-- Dark DataGrid shared style -->
        <Style x:Key="DarkGrid" TargetType="DataGrid">
            <Setter Property="Background"              Value="{StaticResource PanelBg}"/>
            <Setter Property="Foreground"              Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"             Value="{StaticResource BorderBrush2}"/>
            <Setter Property="BorderThickness"         Value="1"/>
            <Setter Property="RowBackground"           Value="{StaticResource PanelBg}"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource CardBg}"/>
            <Setter Property="GridLinesVisibility"     Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2E3548"/>
            <Setter Property="ColumnHeaderHeight"      Value="26"/>
            <Setter Property="FontSize"                Value="11"/>
            <Setter Property="FontFamily"              Value="Consolas"/>
            <Setter Property="SelectionMode"           Value="Single"/>
            <Setter Property="SelectionUnit"           Value="FullRow"/>
            <Setter Property="VerticalScrollBarVisibility"   Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"     Value="{StaticResource CardBg}"/>
            <Setter Property="Foreground"     Value="{StaticResource TextMuted}"/>
            <Setter Property="FontWeight"     Value="SemiBold"/>
            <Setter Property="FontSize"       Value="11"/>
            <Setter Property="Padding"        Value="6,4"/>
            <Setter Property="BorderBrush"    Value="{StaticResource BorderBrush2}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentDim}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="6,3"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid x:Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="52"/>
            <RowDefinition Height="72"/>
            <RowDefinition Height="*" MinHeight="200"/>
            <RowDefinition x:Name="AnalysisRow" Height="180"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto" MinHeight="230"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource PanelBg}"
                BorderBrush="{StaticResource BorderBrush2}"
                BorderThickness="0,0,0,1">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Fill="{StaticResource Accent}" Margin="0,0,10,0"/>
                    <TextBlock Text="FlyLine Profiler"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="  fly line diameter profiler"
                               FontSize="13" Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Project bar (centre) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="New"
                            Style="{StaticResource BtnGhost}"
                            Click="NewProject_Click"
                            ToolTip="New project"/>
                    <Button Content="Open"
                            Style="{StaticResource BtnGhost}"
                            Click="OpenProject_Click"
                            ToolTip="Open project (.flp)"/>
                    <Button Content="Save"
                            Style="{StaticResource BtnSecondary}"
                            Click="SaveProject_Click"
                            ToolTip="Save project"/>
                    <Button Content="Save As"
                            Style="{StaticResource BtnGhost}"
                            Click="SaveProjectAs_Click"
                            ToolTip="Save project as…"/>
                    <Button Content="Close"
                            Style="{StaticResource BtnGhost}"
                            Click="CloseProject_Click"
                            ToolTip="Close project"/>
                    <Separator Style="{StaticResource ToolSep}"/>
                    <TextBlock x:Name="ProjectNameText"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"
                               Text="Untitled"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="?"
                            Style="{StaticResource BtnGhost}"
                            Click="AboutBtn_Click"
                            ToolTip="About FlyLine Profiler"
                            Width="32" Height="32"
                            FontSize="14" FontWeight="Bold"
                            Margin="0,0,8,0"/>
                    <ToggleButton x:Name="DesignModeToggle"
                                  Content="Design Mode"
                                  Style="{StaticResource ToggleBase}"
                                  IsChecked="True"
                                  Click="DesignModeToggle_Click"
                                  ToolTip="Hide scan controls and focus on line design"
                                  Margin="0,0,12,0"/>
                    <StackPanel x:Name="ConnectionPanel" Orientation="Horizontal">
                        <Ellipse x:Name="ConnLed"
                                 Width="10" Height="10"
                                 VerticalAlignment="Center"
                                 Fill="{StaticResource Danger}"
                                 Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding ConnectionStatus}"
                                   Foreground="{StaticResource TextMuted}"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Margin="0,0,16,0"/>
                        <Button Content="Connect"
                                Style="{StaticResource BtnPrimary}"
                                Click="Connect_Click"/>
                        <Button Content="Disconnect"
                                Style="{StaticResource BtnSecondary}"
                                Click="Disconnect_Click"
                                Margin="6,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1"
                Background="{StaticResource PanelBg}"
                BorderBrush="{StaticResource BorderBrush2}"
                BorderThickness="0,0,0,1">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          Margin="12,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- Scan controls (hidden in Design Mode) -->
                    <StackPanel x:Name="ScanButtonsPanel" Orientation="Horizontal">
                        <Button Content="SCAN"
                                Style="{StaticResource BtnPrimary}"
                                Click="StartScan_Click"
                                IsEnabled="{Binding CanControl}"
                                Padding="20,0"/>
                        <Button Content="STOP"
                                Style="{StaticResource BtnDanger}"
                                Click="Stop_Click"
                                Padding="18,0"/>
                        <Button Content="RX ON"
                                Style="{StaticResource BtnSecondary}"
                                Click="ScanOn_Click"
                                IsEnabled="{Binding CanEnableScan}"/>
                        <Button Content="RX OFF"
                                Style="{StaticResource BtnSecondary}"
                                Click="ScanOff_Click"
                                IsEnabled="{Binding ScanReceiving}"/>
                        <Button Content="Clear Scan"
                                Style="{StaticResource BtnDanger}"
                                Click="ClearScan_Click"
                                ToolTip="Discard the acquired scan data so you can run a fresh scan (design is kept)"/>
                        <Separator Style="{StaticResource ToolSep}"/>
                        <Button Content="FAST &lt;"
                                Style="{StaticResource BtnSecondary}"
                                Click="FastO_Click"
                                IsEnabled="{Binding CanControl}"/>
                        <Button Content="FAST >"
                                Style="{StaticResource BtnSecondary}"
                                Click="FastS_Click"
                                IsEnabled="{Binding CanControl}"/>
                        <Button Content="GOTO"
                                Style="{StaticResource BtnSecondary}"
                                Click="Goto_Click"
                                IsEnabled="{Binding CanControl}"/>
                        <Button Content="Status"
                                Style="{StaticResource BtnGhost}"
                                Click="MotorStatus_Click"/>
                        <Separator Style="{StaticResource ToolSep}"/>
                        <Button Content="Set Zero"
                                Style="{StaticResource BtnSecondary}"
                                Click="SetDisplayZero_Click"/>
                        <Button Content="Set Offset"
                                Style="{StaticResource BtnSecondary}"
                                Click="SetOffset_Click"/>
                        <Button Content="Reset Offset"
                                Style="{StaticResource BtnGhost}"
                                Click="ResetOffset_Click"/>
                        <Button Content="Read Raw"
                                Style="{StaticResource BtnGhost}"
                                Click="ReadRaw_Click"/>
                        <Separator Style="{StaticResource ToolSep}"/>
                    </StackPanel>

                    <Button Content="Fit"
                            Style="{StaticResource BtnSecondary}"
                            Click="FitPlot_Click"/>
                    <ToggleButton x:Name="AutoFitToggle"
                                  Content="Auto-Fit"
                                  Style="{StaticResource ToggleBase}"
                                  IsChecked="True"
                                  Click="AutoFitToggle_Click"/>
                    <Button Content="Clear Chart"
                            Style="{StaticResource BtnGhost}"
                            Click="Reset_Click"
                            ToolTip="Reset position and clear chart"/>

                    <Separator Style="{StaticResource ToolSep}"/>

                    <Button Content="Import CSV"
                            Style="{StaticResource BtnSecondary}"
                            Click="ImportCsv_Click"/>
                    <Button Content="Overlay Project"
                            Style="{StaticResource BtnSecondary}"
                            Click="OverlayProject_Click"
                            ToolTip="Load another .flp project as a comparison overlay (design profile + scan)"/>
                    <Button Content="Export CSV"
                            Style="{StaticResource BtnSecondary}"
                            Click="ExportCsv_Click"/>
                    <Button Content="Export PNG"
                            Style="{StaticResource BtnSecondary}"
                            Click="ExportPng_Click"/>
                    <Button Content="Clear Overlays"
                            Style="{StaticResource BtnGhost}"
                            Click="ClearImported_Click"
                            ToolTip="Remove all comparison overlays (imported CSVs and overlaid projects)"/>

                    <!-- Design-mode-only toolbar items — collapsed in scan mode -->
                    <StackPanel x:Name="DesignToolsPanel" Orientation="Horizontal">
                        <Separator Style="{StaticResource ToolSep}"/>

                        <ToggleButton x:Name="MenuDrawSegments"
                                      Content="Draw Segments"
                                      Style="{StaticResource ToggleBase}"
                                      Click="ToggleDrawMode_Click"/>
                        <Button Content="Undo"
                                Style="{StaticResource BtnGhost}"
                                Click="UndoLastNode_Click"
                                ToolTip="Undo last node change (Ctrl+Z) — add, move, delete, edit, reverse, clear"/>
                        <Button Content="Clear Nodes"
                                Style="{StaticResource BtnGhost}"
                                Click="ClearSegments_Click"/>
                        <Button Content="⇄ Reverse"
                                Style="{StaticResource BtnGhost}"
                                Click="ReverseNodes_Click"
                                ToolTip="Flip the profile so the other end becomes the fly tip (position 0)"/>
                        <Button Content="Export Seg. CSV"
                                Style="{StaticResource BtnGhost}"
                                Click="ExportSegmentsCsv_Click"/>
                        <!-- Profile colour picker -->
                        <Grid Margin="4,0,0,0">
                            <Button x:Name="ProfileColorBtn"
                                    Width="28" Height="22"
                                    Background="#DC3232"
                                    BorderBrush="#555" BorderThickness="1"
                                    Click="ProfileColorBtn_Click"
                                    ToolTip="Click to open colour picker"/>
                            <Popup x:Name="ColorPickerPopup"
                                   StaysOpen="False"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=ProfileColorBtn}">
                                <Border Background="White"
                                        BorderBrush="#BBBBBB" BorderThickness="1"
                                        Padding="10"
                                        Effect="{DynamicResource DropShadow}">
                                    <StackPanel Width="180">
                                        <TextBlock Text="Profile Colour"
                                                   Foreground="#555" FontSize="10"
                                                   Margin="0,0,0,7"/>
                                        <!-- Hex input row -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,9">
                                            <Border Background="White"
                                                    BorderBrush="#AAAAAA" BorderThickness="1"
                                                    CornerRadius="3" Padding="4,2">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="#" Foreground="#666"
                                                               VerticalAlignment="Center"
                                                               FontSize="11" Margin="0,0,1,0"/>
                                                    <TextBox x:Name="HexColorBox"
                                                             Width="68" Height="18"
                                                             FontSize="11" MaxLength="6"
                                                             CharacterCasing="Upper"
                                                             Background="Transparent"
                                                             Foreground="#222"
                                                             BorderThickness="0"
                                                             VerticalContentAlignment="Center"
                                                             KeyDown="HexColorBox_KeyDown"/>
                                                </StackPanel>
                                            </Border>
                                            <Button Content="✓"
                                                    Width="26" Height="26" Margin="4,0,0,0"
                                                    FontSize="12"
                                                    Click="ApplyHexColor_Click"
                                                    ToolTip="Apply hex colour"/>
                                        </StackPanel>
                                        <!-- Preset swatches -->
                                        <WrapPanel>
                                            <Button Click="Swatch_Click" Tag="#DC3232" Width="22" Height="22" Margin="2" Background="#DC3232" BorderThickness="0" ToolTip="#DC3232"/>
                                            <Button Click="Swatch_Click" Tag="#3296FF" Width="22" Height="22" Margin="2" Background="#3296FF" BorderThickness="0" ToolTip="#3296FF"/>
                                            <Button Click="Swatch_Click" Tag="#32D278" Width="22" Height="22" Margin="2" Background="#32D278" BorderThickness="0" ToolTip="#32D278"/>
                                            <Button Click="Swatch_Click" Tag="#FFB41E" Width="22" Height="22" Margin="2" Background="#FFB41E" BorderThickness="0" ToolTip="#FFB41E"/>
                                            <Button Click="Swatch_Click" Tag="#C850DC" Width="22" Height="22" Margin="2" Background="#C850DC" BorderThickness="0" ToolTip="#C850DC"/>
                                            <Button Click="Swatch_Click" Tag="#FF6B35" Width="22" Height="22" Margin="2" Background="#FF6B35" BorderThickness="0" ToolTip="#FF6B35"/>
                                            <Button Click="Swatch_Click" Tag="#28C996" Width="22" Height="22" Margin="2" Background="#28C996" BorderThickness="0" ToolTip="#28C996"/>
                                            <Button Click="Swatch_Click" Tag="#FFFFFF" Width="22" Height="22" Margin="2" Background="#FFFFFF" BorderThickness="0" ToolTip="#FFFFFF"/>
                                            <Button Click="Swatch_Click" Tag="#FFD700" Width="22" Height="22" Margin="2" Background="#FFD700" BorderThickness="0" ToolTip="#FFD700"/>
                                            <Button Click="Swatch_Click" Tag="#00CFFF" Width="22" Height="22" Margin="2" Background="#00CFFF" BorderThickness="0" ToolTip="#00CFFF"/>
                                            <Button Click="Swatch_Click" Tag="#FF3CAC" Width="22" Height="22" Margin="2" Background="#FF3CAC" BorderThickness="0" ToolTip="#FF3CAC"/>
                                            <Button Click="Swatch_Click" Tag="#AAAAAA" Width="22" Height="22" Margin="2" Background="#AAAAAA" BorderThickness="0" ToolTip="#AAAAAA"/>
                                        </WrapPanel>
                                        <Button Content="🎨 More colours…"
                                                Margin="0,8,0,0" Height="24" FontSize="11"
                                                Click="PickProfileColor_Click"
                                                ToolTip="Open the full colour picker"/>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>
                        <Button Content="📄 Export PDF"
                                Style="{StaticResource BtnGhost}"
                                Click="ExportPdf_Click"
                                ToolTip="Export design sheet as PDF"/>
                        <!-- Sinking-only tools — hidden for floating lines -->
                        <StackPanel x:Name="SinkingToolsPanel" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Desired sink:" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="4,0,2,0"/>
                            <TextBox x:Name="CompTargetBox"
                                     Text="1.000"
                                     Width="58"
                                     VerticalAlignment="Center"
                                     LostFocus="CompTargetBox_LostFocus"
                                     KeyDown="CompTargetBox_KeyDown"
                                     ToolTip="Target uniform sinking speed for the compensated profile.&#x0a;Typical sink tip classes (AFTM):&#x0a;  Class I : 1.25–2.00 in/s  (slow intermediate)&#x0a;  Class II : 2.00–3.00 in/s&#x0a;  Class III: 2.50–3.50 in/s&#x0a;  Class IV : 3.50–4.50 in/s&#x0a;  Class V  : 4.50–6.00 in/s&#x0a;  Class VI : 6.00–8.00 in/s&#x0a;  Class VII: &gt; 8.00 in/s (very fast)"/>
                            <TextBlock Text="in/s" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="2,0,2,0"/>
                            <TextBlock x:Name="CompTargetCmsLabel"
                                       Foreground="{StaticResource TextMuted}"
                                       VerticalAlignment="Center"
                                       FontStyle="Italic"
                                       Margin="0,0,4,0"/>
                            <Button Content="⚖ Compensate"
                                    Style="{StaticResource BtnSecondary}"
                                    Click="Compensate_Click"
                                    ToolTip="Compute per-slice compensated diameter profile for the target sink speed (slice mass preserved)"/>
                            <Separator Style="{StaticResource ToolSep}"/>
                            <ToggleButton x:Name="SinkMapToggle"
                                          Content="Sink Map"
                                          Style="{StaticResource ToggleBase}"
                                          IsChecked="False"
                                          Click="ShowSinkMap_Click"
                                          ToolTip="Show sinking speed heat-map overlay (blue=slow, red=fast)"/>
                            <ToggleButton x:Name="CompProfileToggle"
                                          Content="Comp. Profile"
                                          Style="{StaticResource ToggleBase}"
                                          IsChecked="False"
                                          Click="ShowCompProfile_Click"
                                          ToolTip="Show compensated step profile — equivalent cylinders per segment (same mass, uniform sink speed)"/>
                        </StackPanel>

                        <ToggleButton x:Name="ShowDesignToggle"
                                      Content="Show Design"
                                      Style="{StaticResource ToggleBase}"
                                      IsChecked="True"
                                      Click="ShowDesignLayer_Click"/>

                        <Separator Style="{StaticResource ToolSep}"/>
                    </StackPanel>

                    <Button Content="Fit View"
                            Style="{StaticResource BtnGhost}"
                            Click="FitView_Click"
                            ToolTip="Fit chart to all visible data"/>
                    <Button x:Name="ShowScanBtn"
                            Content="Hide Scan"
                            Style="{StaticResource BtnGhost}"
                            Click="ShowScanBtn_Click"
                            Margin="10,0,0,0"/>
                    <Button Content="Clear Scan"
                            Style="{StaticResource BtnDanger}"
                            Click="ClearScan_Click"
                            ToolTip="Discard the acquired scan data so you can run a fresh scan (design is kept)"/>

                    <Separator Style="{StaticResource ToolSep}"/>

                    <Button Content="Settings"
                            Style="{StaticResource BtnGhost}"
                            Click="Settings_Click"
                            ToolTip="App settings"/>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Metrics strip -->
        <Border x:Name="MetricsStrip" Grid.Row="2"
                Background="{StaticResource WinBg}"
                BorderBrush="{StaticResource BorderBrush2}"
                BorderThickness="0,0,0,1">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          Margin="16,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                    <Border Style="{StaticResource MetricCard}">
                        <StackPanel>
                            <TextBlock Text="Connection" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding ConnectionStatus}" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCard}">
                        <StackPanel>
                            <TextBlock Text="Motor" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding MotorState}" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource Success}" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCard}" MinWidth="130">
                        <StackPanel>
                            <TextBlock Text="Length" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding CurrentLength}" FontSize="19" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCard}" MinWidth="130">
                        <StackPanel>
                            <TextBlock Text="Diameter" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding CurrentDiameter}" FontSize="19" FontWeight="Bold"
                                       Foreground="{StaticResource Accent}" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCard}">
                        <StackPanel>
                            <TextBlock Text="Display" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding CurrentDisplay}" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCard}">
                        <StackPanel>
                            <TextBlock Text="Speed" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding Speed}" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource Warning}" Margin="0,3,0,0"/>
                            <TextBlock Text="{Binding SpeedStatus}" FontSize="10"
                                       Foreground="{StaticResource TextMuted}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCard}">
                        <StackPanel>
                            <TextBlock Text="Points" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding PointsCount}" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCard}">
                        <StackPanel>
                            <TextBlock Text="Display Zero" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding DisplayZeroText}" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCard}">
                        <StackPanel>
                            <TextBlock Text="Offset" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding OffsetText}" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCard}" MinWidth="200">
                        <StackPanel>
                            <TextBlock Text="GoTo / Status" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding GotoStatus}" FontSize="13"
                                       Foreground="{StaticResource Success}" Margin="0,3,0,0"
                                       TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Chart -->
        <Border Grid.Row="3"
                Background="#161922"
                Margin="12,8,12,0"
                CornerRadius="12"
                BorderBrush="{StaticResource BorderBrush2}"
                BorderThickness="1">
            <ScottPlot:WpfPlot x:Name="PlotControl" Margin="4"/>
        </Border>

        <!-- Analysis chart: mass distribution + cumulative grain weight (design mode only) -->
        <Border x:Name="AnalysisChartPanel"
                Grid.Row="4"
                Background="#161922"
                Margin="12,4,12,0"
                CornerRadius="8"
                BorderBrush="{StaticResource BorderBrush2}"
                BorderThickness="1"
                Visibility="Collapsed">
            <ScottPlot:WpfPlot x:Name="AnalysisPlotControl" Margin="2"/>
        </Border>

        <!-- Collapsible log + chart controls -->
        <Expander x:Name="LogExpander" Grid.Row="5"
                  Margin="12,6,12,0"
                  IsExpanded="False">
            <Expander.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Diagnostic Log"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center"
                               Margin="0,0,24,0"/>
                    <ToggleButton x:Name="SmoothingToggle"
                                  Content="EMA Smoothing"
                                  Style="{StaticResource ToggleBase}"
                                  IsChecked="True"
                                  Height="28"
                                  FontSize="11"
                                  Click="SmoothingToggle_Click"/>
                    <TextBlock Text="alpha"
                               FontSize="11" Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center" Margin="12,0,6,0"/>
                    <Slider x:Name="SmoothingAlphaSlider"
                            Width="100"
                            Minimum="0.01" Maximum="1.00"
                            TickFrequency="0.01"
                            SmallChange="0.01" LargeChange="0.05"
                            IsEnabled="{Binding ElementName=SmoothingToggle, Path=IsChecked}"
                            ValueChanged="SmoothingAlphaSlider_ValueChanged"
                            VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ElementName=MainWin, Path=SmoothingAlphaStatus}"
                               FontSize="11" Foreground="{StaticResource Accent}"
                               VerticalAlignment="Center" Margin="6,0,0,0" Width="34"/>
                    <Button Content="Reset"
                            Style="{StaticResource BtnGhost}"
                            Height="26" Padding="8,0"
                            FontSize="11"
                            IsEnabled="{Binding ElementName=SmoothingToggle, Path=IsChecked}"
                            Click="ResetSmoothingAlpha_Click"/>
                    <Separator Style="{StaticResource ToolSep}" Margin="12,0"/>
                    <TextBlock Text="Line W"
                               FontSize="11" Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Slider x:Name="LineWidthSlider"
                            Width="80"
                            Minimum="1" Maximum="8"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            ValueChanged="LineWidthSlider_ValueChanged"
                            VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ElementName=MainWin, Path=LineWidthStatus}"
                               FontSize="11" Foreground="{StaticResource Accent}"
                               VerticalAlignment="Center" Margin="6,0,0,0" Width="20"/>
                    <Separator Style="{StaticResource ToolSep}" Margin="12,0"/>
                    <TextBlock Text="Opacity"
                               FontSize="11" Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Slider x:Name="FilteredOpacitySlider"
                            Width="80"
                            Minimum="0.05" Maximum="1.00"
                            TickFrequency="0.05"
                            SmallChange="0.05" LargeChange="0.10"
                            ValueChanged="FilteredOpacitySlider_ValueChanged"
                            VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ElementName=MainWin, Path=FilteredOpacityStatus}"
                               FontSize="11" Foreground="{StaticResource Accent}"
                               VerticalAlignment="Center" Margin="6,0,0,0" Width="34"/>
                    <Separator Style="{StaticResource ToolSep}" Margin="12,0"/>
                    <CheckBox x:Name="ChkAutoScroll"
                              Content="Auto-scroll"
                              IsChecked="True"
                              Foreground="{StaticResource TextMuted}"
                              FontSize="11"
                              VerticalAlignment="Center"
                              Margin="0,0,12,0"/>
                    <Button Content="Clear Log"
                            Style="{StaticResource BtnGhost}"
                            Height="26" Padding="8,0"
                            FontSize="11"
                            Click="ClearLog_Click"/>
                    <Slider x:Name="RawOpacitySlider"
                            Width="0" Height="0" Visibility="Collapsed"
                            Minimum="0.05" Maximum="1.00"
                            ValueChanged="RawOpacitySlider_ValueChanged"/>
                </StackPanel>
            </Expander.Header>

            <Border Height="160"
                    Background="{StaticResource LogBg}"
                    BorderBrush="{StaticResource BorderBrush2}"
                    BorderThickness="1"
                    CornerRadius="0,0,10,10"
                    Padding="10">
                <TextBox x:Name="TxtLog"
                         Text="{Binding LogText}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextChanged="TxtLog_TextChanged"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="#8BE0B0"
                         FontFamily="Consolas"
                         FontSize="11"
                         SelectionBrush="#3E6F99"/>
            </Border>
        </Expander>

        <!-- Project panel: Design nodes + Segment table with volumes -->
        <Expander x:Name="DesignProjectExpander"
                  Grid.Row="6"
                  Margin="12,4,12,0"
                  IsExpanded="True">
            <Expander.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Design Project"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0"/>

                    <!-- Line type: Floating / Sinking -->
                    <Border Background="#1C2030" CornerRadius="5" Padding="4,2" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="Floating"
                                         IsChecked="{Binding ElementName=MainWin, Path=IsSinking, Converter={StaticResource InverseBoolConverter}}"
                                         FontSize="11" Foreground="{StaticResource TextMuted}"
                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <RadioButton Content="Sinking"
                                         IsChecked="{Binding ElementName=MainWin, Path=IsSinking}"
                                         FontSize="11" Foreground="{StaticResource TextMuted}"
                                         VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Line format: Shooting Head / Full Line -->
                    <Border Background="#1C2030" CornerRadius="5" Padding="4,2" Margin="0,0,16,0">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="Shooting Head"
                                         IsChecked="{Binding ElementName=MainWin, Path=IsFullLine, Converter={StaticResource InverseBoolConverter}}"
                                         FontSize="11" Foreground="{StaticResource TextMuted}"
                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <RadioButton Content="Full Line"
                                         IsChecked="{Binding ElementName=MainWin, Path=IsFullLine}"
                                         FontSize="11" Foreground="{StaticResource TextMuted}"
                                         VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- AFFTA badge -->
                    <Border Background="#1A2A1A" CornerRadius="5" Padding="8,2" Margin="0,0,16,0">
                        <TextBlock Text="{Binding ElementName=MainWin, Path=AfftaBadge}"
                                   FontSize="11" FontWeight="SemiBold" FontFamily="Consolas"
                                   Foreground="{StaticResource Success}"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock x:Name="TotalsText"
                               Text="{Binding ElementName=MainWin, Path=TotalVolumeText}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource Success}"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0"
                               ToolTipService.ShowDuration="60000"/>
                    <!-- Shared density controls -->
                    <CheckBox Content="Same density"
                              IsChecked="{Binding ElementName=MainWin, Path=UseSharedDensity}"
                              VerticalAlignment="Center"
                              Foreground="{StaticResource TextMuted}"
                              FontSize="11"
                              Margin="0,0,8,0"/>
                    <TextBox x:Name="SharedDensityBox"
                             Width="68"
                             FontSize="11"
                             VerticalAlignment="Center"
                             HorizontalContentAlignment="Center"
                             Text="{Binding ElementName=MainWin, Path=SharedDensity, StringFormat='0.000', UpdateSourceTrigger=LostFocus}"
                             ToolTip="Specific weight in g/cm³ — applies to all segments when Same density is checked"
                             Margin="0,0,4,0"/>
                    <TextBlock Text="g/cm³"
                               FontSize="11"
                               Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center"/>
                    <Button Content="⚖ From weight…"
                            Click="FromWeight_Click"
                            FontSize="11"
                            Padding="6,2"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            Cursor="Hand"
                            ToolTip="Back-calculate density from a measured weight (ρ = m / V)"/>
                    <!-- Water settings for sinking speed -->
                    <Separator Style="{StaticResource ToolSep}" Margin="12,0"/>
                    <TextBlock Text="Water:"
                               FontSize="11"
                               Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <RadioButton x:Name="FreshWaterRadio"
                                 Content="Fresh"
                                 IsChecked="{Binding ElementName=MainWin, Path=WaterIsSalt, Converter={StaticResource InverseBoolConverter}}"
                                 FontSize="11"
                                 Foreground="{StaticResource TextMuted}"
                                 VerticalAlignment="Center"
                                 Margin="0,0,6,0"/>
                    <RadioButton Content="Salt"
                                 IsChecked="{Binding ElementName=MainWin, Path=WaterIsSalt}"
                                 FontSize="11"
                                 Foreground="{StaticResource TextMuted}"
                                 VerticalAlignment="Center"
                                 Margin="0,0,10,0"/>
                    <TextBox Width="44"
                             FontSize="11"
                             VerticalAlignment="Center"
                             HorizontalContentAlignment="Center"
                             Text="{Binding ElementName=MainWin, Path=WaterTempC, StringFormat='0.#', UpdateSourceTrigger=LostFocus}"
                             ToolTip="Water temperature in °C (0–40)"
                             Margin="0,0,4,0"/>
                    <TextBlock Text="°C"
                               FontSize="11"
                               Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Expander.Header>

            <StackPanel>
            <Grid Height="195" Margin="0,2,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Editable nodes DataGrid -->
                <DockPanel Grid.Column="0" Margin="0,0,4,0">
                    <Button DockPanel.Dock="Top"
                            Content="＋ Add Node"
                            Click="AddNode_Click"
                            Margin="0,0,0,2"
                            Padding="4,2"
                            FontSize="11"
                            ToolTip="Append a new node row — edit Position and Diameter directly in the table"/>
                    <Border BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
                        <DataGrid x:Name="NodesDataGrid"
                                  Style="{StaticResource DarkGrid}"
                                  ItemsSource="{Binding ElementName=MainWin, Path=DesignNodes}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="True"
                                  CellEditEnding="NodesDataGrid_CellEditEnding"
                                  PreviewKeyDown="NodesDataGrid_PreviewKeyDown"
                                  ToolTip="Edit position/diameter directly. Del key removes selected row.">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Position (cm)"
                                                   Binding="{Binding PositionCm, StringFormat='0.0'}"
                                                   Width="*"/>
                                <DataGridTextColumn Header="Diameter (mm)"
                                                   Binding="{Binding DiameterMm, StringFormat='0.000'}"
                                                   Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </DockPanel>

                <!-- Segment table -->
                <Border Grid.Column="1"
                        BorderBrush="{StaticResource BorderBrush2}"
                        BorderThickness="1">
                    <DataGrid x:Name="SegmentsDataGrid"
                              Style="{StaticResource DarkGrid}"
                              FontSize="13"
                              ItemsSource="{Binding ElementName=MainWin, Path=ProjectSegments}"
                              AutoGenerateColumns="False"
                              IsReadOnly="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CellEditEnding="SegmentsDataGrid_CellEditEnding">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHead}" Value="True">
                                        <Setter Property="Background" Value="#22305A"/>
                                        <Setter Property="Foreground" Value="#7FB4FF"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#"
                                               Binding="{Binding Index}"
                                               Width="28"
                                               IsReadOnly="True"/>
                            <DataGridCheckBoxColumn x:Name="HeadColumn"
                                                   Header="Head"
                                                   Binding="{Binding IsHead, UpdateSourceTrigger=PropertyChanged}"
                                                   Width="44"/>
                            <DataGridTextColumn Header="Name"
                                               Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                               Width="90"/>
                            <DataGridTextColumn Header="Start Ø (mm)"
                                               Binding="{Binding StartDiameterMm, StringFormat='0.000'}"
                                               Width="105"/>
                            <DataGridTextColumn Header="End Ø (mm)"
                                               Binding="{Binding EndDiameterMm, StringFormat='0.000'}"
                                               Width="95"/>
                            <DataGridTextColumn Header="Length (cm)"
                                               Binding="{Binding LengthCm, StringFormat='0.0'}"
                                               Width="90"/>
                            <DataGridTextColumn Header="Shape"
                                               Binding="{Binding Shape}"
                                               Width="70"
                                               IsReadOnly="True"/>
                            <DataGridTextColumn Header="Taper (mm/m)"
                                               Binding="{Binding TaperText}"
                                               Width="100"
                                               IsReadOnly="True"/>
                            <DataGridTextColumn Header="Volume (cm³)"
                                               Binding="{Binding VolumeText}"
                                               Width="90"
                                               IsReadOnly="True"/>
                            <DataGridTextColumn x:Name="SpWeightColumn"
                                               Header="Sp.W. (g/cm³)"
                                               Binding="{Binding SpecWeightGCm3, StringFormat='0.000', UpdateSourceTrigger=PropertyChanged}"
                                               Width="105"/>
                            <DataGridTextColumn Header="Mass (g)"
                                               Binding="{Binding MassText}"
                                               Width="80"
                                               IsReadOnly="True"/>
                            <DataGridTextColumn Header="Sink (in/s)"
                                               Binding="{Binding SinkSpeedText}"
                                               Width="90"
                                               IsReadOnly="True"/>
                            <DataGridTextColumn Header="Comp. Sink (in/s)"
                                               Binding="{Binding CompSpeedText}"
                                               Width="115"
                                               IsReadOnly="True"/>
                            <DataGridTextColumn Header="Comp. Start Ø (mm)"
                                               Binding="{Binding CompStartDiamText}"
                                               Width="120"
                                               IsReadOnly="True"/>
                            <DataGridTextColumn Header="Comp. End Ø (mm)"
                                               Binding="{Binding CompEndDiamText}"
                                               Width="115"
                                               IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

            <!-- ── Colour sections panel ──────────────────────────────── -->
            <Grid Margin="0,6,0,4" Height="140">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="260"/>
                </Grid.ColumnDefinitions>

                <!-- Left: colour sections DataGrid -->
                <DockPanel Grid.Column="0" Margin="0,0,6,0">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,3">
                        <TextBlock Text="Colour Sections"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMuted}"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Button Content="＋ Add Section"
                                Click="AddColorSection_Click"
                                Padding="6,2" FontSize="11"
                                ToolTip="Add a colour band (start/end in cm, hex colour)"/>
                    </StackPanel>
                    <Border BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
                        <DataGrid x:Name="ColorSectionsDataGrid"
                                  Style="{StaticResource DarkGrid}"
                                  ItemsSource="{Binding ElementName=MainWin, Path=ColorSections}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="True"
                                  CellEditEnding="ColorSectionsDataGrid_CellEditEnding"
                                  PreviewKeyDown="ColorSectionsDataGrid_PreviewKeyDown"
                                  ToolTip="Define coloured bands. Del removes selected row.">
                            <DataGrid.Columns>
                                <!-- Colour picker button -->
                                <DataGridTemplateColumn Header="Color" Width="44" IsReadOnly="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Width="32" Height="18" Margin="2,1"
                                                    Background="{Binding ColorHex, Converter={StaticResource HexToBrush}}"
                                                    BorderBrush="#888" BorderThickness="1"
                                                    Tag="{Binding}"
                                                    Click="SectionColorBtn_Click"
                                                    ToolTip="Click to pick colour"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Start (cm)"
                                                   Binding="{Binding StartCm, StringFormat='0.0'}"
                                                   Width="80"/>
                                <DataGridTextColumn Header="End (cm)"
                                                   Binding="{Binding EndCm, StringFormat='0.0'}"
                                                   Width="80"/>
                                <DataGridTextColumn Header="Color (hex)"
                                                   Binding="{Binding ColorHex}"
                                                   Width="90"/>
                                <DataGridTextColumn Header="Label"
                                                   Binding="{Binding Label}"
                                                   Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </DockPanel>

                <!-- Right: core + colour note fields -->
                <DockPanel Grid.Column="1">
                    <TextBlock DockPanel.Dock="Top"
                               Text="Core (printed in PDF)"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}"
                               Margin="0,0,0,3"/>
                    <ComboBox x:Name="CoreTypeCombo"
                              DockPanel.Dock="Top"
                              IsEditable="True"
                              Text="{Binding ElementName=MainWin, Path=CoreType, UpdateSourceTrigger=LostFocus}"
                              FontSize="11"
                              Margin="0,0,0,8"
                              ToolTip="Core material — pick a common type or type your own"/>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Laser mark (printed in PDF)"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}"
                               Margin="0,0,0,3"/>
                    <TextBox DockPanel.Dock="Top"
                             Text="{Binding ElementName=MainWin, Path=LaserMark, UpdateSourceTrigger=PropertyChanged}"
                             Background="#1A1E2A"
                             Foreground="{StaticResource TextPrimary}"
                             BorderBrush="{StaticResource BorderBrush2}"
                             BorderThickness="1"
                             FontSize="11"
                             Padding="6,4"
                             Margin="0,0,0,4"
                             ToolTip="Text laser-marked on the line (e.g. RB LW6 F 160gr)"/>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="55"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="55"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="mm from tip:" FontSize="10"
                                   Foreground="{StaticResource TextMuted}"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding ElementName=MainWin, Path=LaserMarkFromTip, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#1A1E2A"
                                 Foreground="{StaticResource TextPrimary}"
                                 BorderBrush="{StaticResource BorderBrush2}"
                                 BorderThickness="1" FontSize="11" Padding="4,2"
                                 ToolTip="Mark position in mm measured from the tip (0). Leave empty if no mark at the tip side"/>
                        <TextBlock Grid.Column="3" Text="mm from end:" FontSize="10"
                                   Foreground="{StaticResource TextMuted}"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Grid.Column="4"
                                 Text="{Binding ElementName=MainWin, Path=LaserMarkFromEnd, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#1A1E2A"
                                 Foreground="{StaticResource TextPrimary}"
                                 BorderBrush="{StaticResource BorderBrush2}"
                                 BorderThickness="1" FontSize="11" Padding="4,2"
                                 ToolTip="Mark position in mm measured from the rear end. Leave empty if no mark at the rear side"/>
                    </Grid>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Color note (printed in PDF)"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}"
                               Margin="0,0,0,3"/>
                    <TextBox Text="{Binding ElementName=MainWin, Path=ColorNote, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Background="#1A1E2A"
                             Foreground="{StaticResource TextPrimary}"
                             BorderBrush="{StaticResource BorderBrush2}"
                             BorderThickness="1"
                             FontSize="11"
                             Padding="6,4"
                             ToolTip="Free text description of the line colour (e.g. Red / White / Green in equal parts)"/>
                </DockPanel>
            </Grid>

            </StackPanel>
        </Expander>

        <!-- ── Section colour picker popup (shared, opened from DataGrid swatch buttons) ── -->
        <Popup x:Name="SectionColorPopup"
               StaysOpen="False"
               Placement="Mouse">
            <Border Background="White" BorderBrush="#BBBBBB" BorderThickness="1"
                    Padding="10">
                <StackPanel Width="180">
                    <TextBlock Text="Section Colour" Foreground="#555" FontSize="10" Margin="0,0,0,7"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,9">
                        <Border Background="White" BorderBrush="#AAAAAA" BorderThickness="1"
                                CornerRadius="3" Padding="4,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="#" Foreground="#666" VerticalAlignment="Center"
                                           FontSize="11" Margin="0,0,1,0"/>
                                <TextBox x:Name="SectionHexBox"
                                         Width="68" Height="18" FontSize="11" MaxLength="6"
                                         CharacterCasing="Upper" Background="Transparent"
                                         Foreground="#222" BorderThickness="0"
                                         VerticalContentAlignment="Center"
                                         KeyDown="SectionHexBox_KeyDown"/>
                            </StackPanel>
                        </Border>
                        <Button Content="✓" Width="26" Height="26" Margin="4,0,0,0"
                                FontSize="12" Click="ApplySectionHexColor_Click"
                                ToolTip="Apply"/>
                    </StackPanel>
                    <WrapPanel>
                        <Button Click="SectionSwatch_Click" Tag="#DC3232" Width="22" Height="22" Margin="2" Background="#DC3232" BorderThickness="0" ToolTip="Red"/>
                        <Button Click="SectionSwatch_Click" Tag="#F5F5F5" Width="22" Height="22" Margin="2" Background="#F5F5F5" BorderThickness="1" BorderBrush="#CCC" ToolTip="White"/>
                        <Button Click="SectionSwatch_Click" Tag="#28A428" Width="22" Height="22" Margin="2" Background="#28A428" BorderThickness="0" ToolTip="Green"/>
                        <Button Click="SectionSwatch_Click" Tag="#3296FF" Width="22" Height="22" Margin="2" Background="#3296FF" BorderThickness="0" ToolTip="Blue"/>
                        <Button Click="SectionSwatch_Click" Tag="#FFB41E" Width="22" Height="22" Margin="2" Background="#FFB41E" BorderThickness="0" ToolTip="Amber"/>
                        <Button Click="SectionSwatch_Click" Tag="#C850DC" Width="22" Height="22" Margin="2" Background="#C850DC" BorderThickness="0" ToolTip="Purple"/>
                        <Button Click="SectionSwatch_Click" Tag="#FF6B35" Width="22" Height="22" Margin="2" Background="#FF6B35" BorderThickness="0" ToolTip="Orange"/>
                        <Button Click="SectionSwatch_Click" Tag="#FFD700" Width="22" Height="22" Margin="2" Background="#FFD700" BorderThickness="0" ToolTip="Yellow"/>
                        <Button Click="SectionSwatch_Click" Tag="#00CFFF" Width="22" Height="22" Margin="2" Background="#00CFFF" BorderThickness="0" ToolTip="Cyan"/>
                        <Button Click="SectionSwatch_Click" Tag="#FF3CAC" Width="22" Height="22" Margin="2" Background="#FF3CAC" BorderThickness="0" ToolTip="Pink"/>
                        <Button Click="SectionSwatch_Click" Tag="#222222" Width="22" Height="22" Margin="2" Background="#222222" BorderThickness="0" ToolTip="Black"/>
                        <Button Click="SectionSwatch_Click" Tag="#AAAAAA" Width="22" Height="22" Margin="2" Background="#AAAAAA" BorderThickness="0" ToolTip="Grey"/>
                    </WrapPanel>
                    <Button Content="🎨 More colours…"
                            Margin="0,8,0,0" Height="24" FontSize="11"
                            Click="PickSectionColor_Click"
                            ToolTip="Open the full colour picker"/>
                </StackPanel>
            </Border>
        </Popup>

        <!-- Status bar -->
        <Border Grid.Row="7"
                Background="{StaticResource PanelBg}"
                BorderBrush="{StaticResource BorderBrush2}"
                BorderThickness="0,1,0,0"
                Margin="0,6,0,0">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding ElementName=MainWin, Path=UiStatus}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource Accent}"
                           FontSize="11"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding ElementName=MainWin, Path=DrawModeStatus}"
                           Foreground="{StaticResource Danger}"
                           FontWeight="SemiBold"
                           FontSize="11"
                           Margin="16,0,0,0"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3"
                           Text="{Binding ElementName=MainWin, Path=AutoFitStatus}"
                           Foreground="{StaticResource TextMuted}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"/>
                <TextBlock Grid.Column="4"
                           Text="{Binding ElementName=MainWin, Path=ImportedSeriesStatus}"
                           Foreground="{StaticResource TextMuted}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"/>
                <TextBlock Grid.Column="5"
                           Text="{Binding ElementName=MainWin, Path=HoverCoordsStatus}"
                           FontFamily="Consolas"
                           FontSize="11"
                           Foreground="{StaticResource Success}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

    </Grid>

</Window>