<Window
        x:Class="DiametroLineaDesktop.Views.MainWindow"
        x:Name="MainWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        mc:Ignorable="d"
        Title="FlyLine Profiler"
        Height="900"
        Width="1400"
        MinHeight="680"
        MinWidth="900"
        Background="#12151C"
        FontFamily="Segoe UI">

    <Window.Resources>

        <!-- â”€â”€ Colours â”€â”€ -->
        <SolidColorBrush x:Key="WinBg"        Color="#12151C"/>
        <SolidColorBrush x:Key="PanelBg"      Color="#1C2030"/>
        <SolidColorBrush x:Key="CardBg"       Color="#232837"/>
        <SolidColorBrush x:Key="BorderBrush2" Color="#2E3548"/>
        <SolidColorBrush x:Key="Accent"       Color="#2D7DD2"/>
        <SolidColorBrush x:Key="AccentDim"    Color="#1A4F8A"/>
        <SolidColorBrush x:Key="Danger"       Color="#E85454"/>
        <SolidColorBrush x:Key="DangerDim"    Color="#7A2020"/>
        <SolidColorBrush x:Key="Success"      Color="#28C996"/>
        <SolidColorBrush x:Key="Warning"      Color="#F5A623"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#E2E8F4"/>
        <SolidColorBrush x:Key="TextMuted"    Color="#7A8499"/>
        <SolidColorBrush x:Key="LogBg"        Color="#0D0F16"/>

        <!-- â”€â”€ Button base â”€â”€ -->
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Height"          Value="34"/>
            <Setter Property="Padding"         Value="14,0"/>
            <Setter Property="Margin"          Value="2,0"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.65"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"  Value="{StaticResource Accent}"/>
            <Setter Property="Foreground"  Value="White"/>
        </Style>

        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"  Value="{StaticResource Danger}"/>
            <Setter Property="Foreground"  Value="White"/>
        </Style>

        <Style x:Key="BtnSecondary" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"  Value="#2C3245"/>
            <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
        </Style>

        <Style x:Key="BtnGhost" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Foreground"  Value="{StaticResource TextMuted}"/>
        </Style>

        <!-- â”€â”€ Toggle button â”€â”€ -->
        <Style x:Key="ToggleBase" TargetType="ToggleButton">
            <Setter Property="Height"          Value="34"/>
            <Setter Property="Padding"         Value="14,0"/>
            <Setter Property="Margin"          Value="2,0"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background"      Value="#2C3245"/>
            <Setter Property="Foreground"      Value="{StaticResource TextMuted}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentDim}"/>
                                <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- â”€â”€ Separator between button groups â”€â”€ -->
        <Style x:Key="ToolSep" TargetType="Separator">
            <Setter Property="Width"      Value="1"/>
            <Setter Property="Height"     Value="22"/>
            <Setter Property="Margin"     Value="8,0"/>
            <Setter Property="Background" Value="#2E3548"/>
        </Style>

        <!-- â”€â”€ Metric card â”€â”€ -->
        <Style x:Key="MetricCard" TargetType="Border">
            <Setter Property="Background"       Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource BorderBrush2}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="10"/>
            <Setter Property="Padding"          Value="14,8"/>
            <Setter Property="Margin"           Value="0,0,8,0"/>
            <Setter Property="MinWidth"         Value="110"/>
        </Style>

        <!-- â”€â”€ Slider â”€â”€ -->
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>    <!-- header bar       -->
            <RowDefinition Height="52"/>    <!-- toolbar          -->
            <RowDefinition Height="72"/>    <!-- metrics strip    -->
            <RowDefinition Height="*"/>     <!-- chart            -->
            <RowDefinition Height="Auto"/>  <!-- collapsible log  -->
            <RowDefinition Height="28"/>    <!-- status bar       -->
        </Grid.RowDefinitions>

        <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
             ROW 0 â€” Header bar
             â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
        <Border Grid.Row="0"
                Background="{StaticResource PanelBg}"
                BorderBrush="{StaticResource BorderBrush2}"
                BorderThickness="0,0,0,1">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Fill="{StaticResource Accent}" Margin="0,0,10,0"/>
                    <TextBlock Text="FlyLine Profiler"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="  diametro linea"
                               FontSize="13"
                               Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Connection controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="ConnLed"
                             Width="10" Height="10"
                             VerticalAlignment="Center"
                             Fill="{StaticResource Danger}"/>
                    <TextBlock Text="{Binding ConnectionStatus}"
                               Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Margin="0,0,16,0"/>
                    <Button Content="Connetti"
                            Style="{StaticResource BtnPrimary}"
                            Click="Connect_Click"/>
                    <Button Content="Disconnetti"
                            Style="{StaticResource BtnSecondary}"
                            Click="Disconnect_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
             ROW 1 â€” Toolbar
             â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
        <Border Grid.Row="1"
                Background="{StaticResource PanelBg}"
                BorderBrush="{StaticResource BorderBrush2}"
                BorderThickness="0,0,0,1">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          Margin="12,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- Scansione -->
                    <Button Content="â–¶  SCAN"
                            Style="{StaticResource BtnPrimary}"
                            Click="StartScan_Click"
                            IsEnabled="{Binding CanControl}"
                            Padding="18,0"/>
                    <Button Content="â–   STOP"
                            Style="{StaticResource BtnDanger}"
                            Click="Stop_Click"
                            Padding="16,0"/>
                    <Button Content="RX ON"
                            Style="{StaticResource BtnSecondary}"
                            Click="ScanOn_Click"
                            IsEnabled="{Binding CanEnableScan}"/>
                    <Button Content="RX OFF"
                            Style="{StaticResource BtnSecondary}"
                            Click="ScanOff_Click"
                            IsEnabled="{Binding ScanReceiving}"/>

                    <Separator Style="{StaticResource ToolSep}"/>

                    <!-- Motore -->
                    <Button Content="â—€ FAST"
                            Style="{StaticResource BtnSecondary}"
                            Click="FastO_Click"
                            IsEnabled="{Binding CanControl}"/>
                    <Button Content="FAST â–¶"
                            Style="{StaticResource BtnSecondary}"
                            Click="FastS_Click"
                            IsEnabled="{Binding CanControl}"/>
                    <Button Content="âŠ• GOTO"
                            Style="{StaticResource BtnSecondary}"
                            Click="Goto_Click"
                            IsEnabled="{Binding CanControl}"/>
                    <Button Content="Stato"
                            Style="{StaticResource BtnGhost}"
                            Click="MotorStatus_Click"/>

                    <Separator Style="{StaticResource ToolSep}"/>

                    <!-- Calibrazione -->
                    <Button Content="âŠ™ Zero"
                            Style="{StaticResource BtnSecondary}"
                            Click="SetDisplayZero_Click"/>
                    <Button Content="â†º Offsetâ€¦"
                            Style="{StaticResource BtnSecondary}"
                            Click="SetOffset_Click"/>
                    <Button Content="Reset offset"
                            Style="{StaticResource BtnGhost}"
                            Click="ResetOffset_Click"/>
                    <Button Content="Raw"
                            Style="{StaticResource BtnGhost}"
                            Click="ReadRaw_Click"/>

                    <Separator Style="{StaticResource ToolSep}"/>

                    <!-- Vista grafico -->
                    <Button Content="âŠž Adatta"
                            Style="{StaticResource BtnSecondary}"
                            Click="FitPlot_Click"/>
                    <ToggleButton x:Name="AutoFitToggle"
                                  Content="Auto-fit"
                                  Style="{StaticResource ToggleBase}"
                                  IsChecked="True"
                                  Click="AutoFitToggle_Click"/>
                    <Button Content="Azzera"
                            Style="{StaticResource BtnGhost}"
                            Click="Reset_Click"
                            ToolTip="Azzera posizione e cancella grafico"/>

                    <Separator Style="{StaticResource ToolSep}"/>

                    <!-- Dati -->
                    <Button Content="ðŸ“¥Import CSV"
                            Style="{StaticResource BtnSecondary}"
                            Click="ImportCsv_Click"/>
                    <Button Content="ðŸ“¤Export CSV"
                            Style="{StaticResource BtnSecondary}"
                            Click="ExportCsv_Click"/>
                    <Button Content="ðŸ–¼PNG"
                            Style="{StaticResource BtnSecondary}"
                            Click="ExportPng_Click"/>
                    <Button Content="âœ• Importati"
                            Style="{StaticResource BtnGhost}"
                            Click="ClearImported_Click"/>

                    <Separator Style="{StaticResource ToolSep}"/>

                    <!-- Segmenti -->
                    <ToggleButton x:Name="MenuDrawSegments"
                                  Content="âœ Segmenti"
                                  Style="{StaticResource ToggleBase}"
                                  Click="ToggleDrawMode_Click"/>
                    <Button Content="â†©"
                            Style="{StaticResource BtnGhost}"
                            Click="UndoLastNode_Click"
                            ToolTip="Annulla ultimo nodo"
                            Padding="10,0"/>
                    <Button Content="âœ• Nodi"
                            Style="{StaticResource BtnGhost}"
                            Click="ClearSegments_Click"/>
                    <Button Content="ðŸ’¾Salva nodi"
                            Style="{StaticResource BtnGhost}"
                            Click="SaveNodes_Click"/>
                    <Button Content="ðŸ“‚Carica nodi"
                            Style="{StaticResource BtnGhost}"
                            Click="LoadNodes_Click"/>
                    <Button Content="ðŸ“¤Seg. CSV"
                            Style="{StaticResource BtnGhost}"
                            Click="ExportSegmentsCsv_Click"/>

                    <Separator Style="{StaticResource ToolSep}"/>

                    <!-- Impostazioni -->
                    <Button Content="âš™"
                            Style="{StaticResource BtnGhost}"
                            Click="Settings_Click"
                            FontSize="16"
                            Padding="10,0"
                            ToolTip="Impostazioni"/>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
             ROW 2 â€” Metrics strip
             â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
        <Border Grid.Row="2"
                Background="{StaticResource WinBg}"
                BorderBrush="{StaticResource BorderBrush2}"
                BorderThickness="0,0,0,1">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          Margin="16,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                    <Border Style="{StaticResource MetricCard}">
                        <StackPanel>
                            <TextBlock Text="Connessione" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding ConnectionStatus}" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCard}">
                        <StackPanel>
                            <TextBlock Text="Motore" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding MotorState}" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource Success}" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCard}" MinWidth="130">
                        <StackPanel>
                            <TextBlock Text="Lunghezza" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding CurrentLength}" FontSize="19" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCard}" MinWidth="130">
                        <StackPanel>
                            <TextBlock Text="Diametro" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding CurrentDiameter}" FontSize="19" FontWeight="Bold"
                                       Foreground="{StaticResource Accent}" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCard}">
                        <StackPanel>
                            <TextBlock Text="Display" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding CurrentDisplay}" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCard}">
                        <StackPanel>
                            <TextBlock Text="VelocitÃ " FontSize="10" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding Speed}" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource Warning}" Margin="0,3,0,0"/>
                            <TextBlock Text="{Binding SpeedStatus}" FontSize="10"
                                       Foreground="{StaticResource TextMuted}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCard}">
                        <StackPanel>
                            <TextBlock Text="Punti" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding PointsCount}" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCard}">
                        <StackPanel>
                            <TextBlock Text="Zero display" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding DisplayZeroText}" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCard}">
                        <StackPanel>
                            <TextBlock Text="Offset" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding OffsetText}" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCard}" MinWidth="200">
                        <StackPanel>
                            <TextBlock Text="GoTo / Stato" FontSize="10" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding GotoStatus}" FontSize="13"
                                       Foreground="{StaticResource Success}" Margin="0,3,0,0"
                                       TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
             ROW 3 â€” Chart
             â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
        <Border Grid.Row="3"
                Background="#161922"
                Margin="12,8,12,0"
                CornerRadius="12"
                BorderBrush="{StaticResource BorderBrush2}"
                BorderThickness="1">
            <ScottPlot:WpfPlot x:Name="PlotControl" Margin="4"/>
        </Border>

        <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
             ROW 4 â€” Collapsible log + chart controls
             â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
        <Expander Grid.Row="4"
                  Margin="12,6,12,0"
                  IsExpanded="False">
            <Expander.Header>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Log diagnostico"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center"
                               Margin="0,0,24,0"/>
                    <!-- Smoothing controls inline in header -->
                    <ToggleButton x:Name="SmoothingToggle"
                                  Content="Smoothing EMA"
                                  Style="{StaticResource ToggleBase}"
                                  IsChecked="True"
                                  Height="28"
                                  FontSize="11"
                                  Click="SmoothingToggle_Click"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock Text="Î±" FontSize="12" Foreground="{StaticResource TextMuted}"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Slider x:Name="SmoothingAlphaSlider"
                                Width="100"
                                Minimum="0.01" Maximum="1.00"
                                TickFrequency="0.01"
                                IsSnapToTickEnabled="False"
                                SmallChange="0.01" LargeChange="0.05"
                                IsEnabled="{Binding ElementName=SmoothingToggle, Path=IsChecked}"
                                ValueChanged="SmoothingAlphaSlider_ValueChanged"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ElementName=MainWin, Path=SmoothingAlphaStatus}"
                                   FontSize="11" Foreground="{StaticResource Accent}"
                                   VerticalAlignment="Center" Margin="6,0,0,0" Width="34"/>
                        <Button Content="â†º"
                                Style="{StaticResource BtnGhost}"
                                Height="26" Width="26" Padding="0"
                                FontSize="14"
                                IsEnabled="{Binding ElementName=SmoothingToggle, Path=IsChecked}"
                                Click="ResetSmoothingAlpha_Click"/>
                    </StackPanel>
                    <Separator Style="{StaticResource ToolSep}" Margin="12,0"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Linea" FontSize="11" Foreground="{StaticResource TextMuted}"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Slider x:Name="LineWidthSlider"
                                Width="80"
                                Minimum="1" Maximum="8"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                ValueChanged="LineWidthSlider_ValueChanged"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ElementName=MainWin, Path=LineWidthStatus}"
                                   FontSize="11" Foreground="{StaticResource Accent}"
                                   VerticalAlignment="Center" Margin="6,0,0,0" Width="20"/>
                    </StackPanel>
                    <Separator Style="{StaticResource ToolSep}" Margin="12,0"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Opac." FontSize="11" Foreground="{StaticResource TextMuted}"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Slider x:Name="FilteredOpacitySlider"
                                Width="80"
                                Minimum="0.05" Maximum="1.00"
                                TickFrequency="0.05"
                                SmallChange="0.05" LargeChange="0.10"
                                ValueChanged="FilteredOpacitySlider_ValueChanged"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ElementName=MainWin, Path=FilteredOpacityStatus}"
                                   FontSize="11" Foreground="{StaticResource Accent}"
                                   VerticalAlignment="Center" Margin="6,0,0,0" Width="34"/>
                    </StackPanel>
                    <Separator Style="{StaticResource ToolSep}" Margin="12,0"/>
                    <CheckBox x:Name="ChkAutoScroll"
                              Content="Auto-scroll"
                              IsChecked="True"
                              Foreground="{StaticResource TextMuted}"
                              FontSize="11"
                              VerticalAlignment="Center"
                              Margin="0,0,12,0"/>
                    <Button Content="Pulisci log"
                            Style="{StaticResource BtnGhost}"
                            Height="26"
                            FontSize="11"
                            Click="ClearLog_Click"/>
                    <!-- RawOpacity hidden but kept for binding -->
                    <Slider x:Name="RawOpacitySlider"
                            Width="0" Height="0" Visibility="Collapsed"
                            Minimum="0.05" Maximum="1.00"
                            ValueChanged="RawOpacitySlider_ValueChanged"/>
                </StackPanel>
            </Expander.Header>

            <Border Height="160"
                    Background="{StaticResource LogBg}"
                    BorderBrush="{StaticResource BorderBrush2}"
                    BorderThickness="1"
                    CornerRadius="0,0,10,10"
                    Padding="10">
                <TextBox x:Name="TxtLog"
                         Text="{Binding LogText}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextChanged="TxtLog_TextChanged"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="#8BE0B0"
                         FontFamily="Consolas"
                         FontSize="11"
                         SelectionBrush="#3E6F99"/>
            </Border>
        </Expander>

        <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
             ROW 5 â€” Status bar
             â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
        <Border Grid.Row="5"
                Background="{StaticResource PanelBg}"
                BorderBrush="{StaticResource BorderBrush2}"
                BorderThickness="0,1,0,0"
                Margin="0,6,0,0">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding ElementName=MainWin, Path=UiStatus}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource Accent}"
                           FontSize="11"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding ElementName=MainWin, Path=DrawModeStatus}"
                           Foreground="{StaticResource Danger}"
                           FontWeight="SemiBold"
                           FontSize="11"
                           Margin="16,0,0,0"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3"
                           Text="{Binding ElementName=MainWin, Path=AutoFitStatus}"
                           Foreground="{StaticResource TextMuted}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"/>
                <TextBlock Grid.Column="4"
                           Text="{Binding ElementName=MainWin, Path=ImportedSeriesStatus}"
                           Foreground="{StaticResource TextMuted}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"/>
                <TextBlock Grid.Column="5"
                           Text="{Binding ElementName=MainWin, Path=HoverCoordsStatus}"
                           FontFamily="Consolas"
                           FontSize="11"
                           Foreground="{StaticResource Success}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

    </Grid>


</Window>

